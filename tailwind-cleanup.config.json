        "32": "2.25rem", "34": "2.25rem", "36": "2.25rem",
        "38": "2.25rem", "42": "2.25rem",
        "48": "3.25rem", "52": "3.25rem"
      },
      "spacing": {
        "2": "0.125rem", "3": "0.125rem",
        "4": "0.375rem", "5": "0.375rem", "6": "0.375rem",
        "8": "0.625rem", "9": "0.625rem", "10": "0.625rem",
        "12": "0.875rem", "13": "0.875rem", "14": "0.875rem", "15": "0.875rem",
        "16": "1.125rem", "17": "1.125rem", "18": "1.125rem", "19": "1.125rem", "20": "1.125rem",
        "22": "1.5rem", "24": "1.5rem", "25": "1.5rem", "26": "1.5rem",
        "28": "2rem", "30": "2rem", "32": "2rem", "34": "2rem", "36": "2rem",
        "38": "3rem", "40": "3rem", "42": "3rem", "44": "3rem",
        "48": "3rem", "50": "3rem",
        "60": "5rem", "70": "5rem", "80": "5rem", "96": "5rem",
        "100": "8.125rem", "120": "8.125rem", "130": "8.125rem",
        "140": "8.125rem", "150": "8.125rem"
      }
    },
    "em": {
      "tracking": {
        "-.035em": "-.025em",
        "-.025em": "-.025em",
        "-.02em":  "-.025em",
        "-.015em": "-.025em",
        ".005em":  "normal",
        ".02em":   "normal",
        ".03em":   ".05em",
        ".04em":   ".05em",
        ".05em":   ".05em",
        ".06em":   ".05em",
        ".07em":   ".05em",
        ".08em":   ".12em",
        ".1em":    ".12em",
        ".12em":   ".12em",
        ".14em":   ".12em",
        ".15em":   ".12em",
        ".18em":   ".22em",
        ".2em":    ".22em",
        ".22em":   ".22em",
        ".25em":   ".22em"
      }
    },
    "unitless": {
      "leading": {
        "0.95": "1.05", ".95": "1.05",
        "1.05": "1.05",
        "1.08": "1.05",
        "1.1":  "1.05",
        "1.15": "1.2",
        "1.18": "1.2",
        "1.2":  "1.2",
        "1.25": "1.2",
        "1.3":  "1.4",
        "1.35": "1.4",
        "1.4":  "1.4",
        "1.45": "1.4",
        "1.5":  "1.55",
        "1.55": "1.55",
        "1.6":  "1.55",
        "1.65": "1.7",
        "1.7":  "1.7",
        "1.72": "1.7"
      }
    }
  },
  "colors": {
    "rgbMap": {
      "91,174,248": "blue",
      "255,59,110": "pink",
      "108,197,194": "teal",
      "236,235,229": "text"
    },
    "alphaBuckets": [
      { "maxAlpha": 0.12, "bucket": 10 },
      { "maxAlpha": 0.20, "bucket": 15 },
      { "maxAlpha": 0.38, "bucket": 30 },
      { "maxAlpha": 1.00, "bucket": 45 }
    ],
    "numericAliases": {
      "1": "bg",
      "2": "bg-elevated",
      "3": "bg-card",
      "4": "text",
      "5": "text-dim",
      "6": "accent"
    }
  },
  "verify": {
    "command": "npm run build"
  },
  "reports": {
    "dir": "tailwind-cleanup-reports"
  }
}
