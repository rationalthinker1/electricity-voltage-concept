{
  "$schema": "../schema/tailwind-cleanup.config.schema.json",
  "version": "0.1.0",
  "scan": {
    "paths": ["src"],
    "extensions": [".tsx", ".ts"],
    "excludeDirs": ["src/styles", "node_modules", "dist", ".git"],
    "excludeFiles": ["routeTree.gen.ts"],
    "css": { "include": false, "recipesOnly": true }
  },
  "scales": {
    "text": {
      "0.625rem": "1",
      "0.6875rem": "2",
      "0.75rem": "3",
      "0.8125rem": "4",
      "0.875rem": "5",
      "1.0625rem": "6",
      "1.125rem": "7",
      "1.5rem": "8",
      "2.25rem": "9",
      "3.25rem": "10"
    },
    "tracking": {
      "-.025em": "1",
      "-0.025em": "1",
      ".05em": "2",
      "0.05em": "2",
      ".12em": "3",
      "0.12em": "3",
      ".22em": "4",
      "0.22em": "4"
    },
    "leading": {
      "1.05": "1",
      "1.2":  "2",
      "1.4":  "3",
      "1.55": "4",
      "1.7":  "5"
    },
    "spacing": {
      "rem": {
        "0.125rem":  "xxs",
        "0.25rem":   "xs",
        "0.5rem":    "sm",
        "0.75rem":   "md",
        "1rem":      "lg",
        "1.5rem":    "xl",
        "2rem":      "2xl",
        "3rem":      "3xl",
        "5rem":      "4xl",
        "8.125rem":  "5xl"
      },
      "px": {
        "1": "xxs", "2": "xxs", "3": "xxs",
        "6": "sm", "8": "sm",
        "11": "md", "12": "md",
        "14": "lg", "16": "lg", "18": "lg",
        "22": "icon",
        "28": "2xl", "30": "2xl", "32": "2xl",
        "36": "icon-lg",
        "48": "3xl", "52": "3xl", "56": "3xl",
        "72": "4xl",
        "220": "panel-sm", "240": "panel-sm", "260": "panel-sm",
        "280": "panel", "320": "panel", "360": "panel",
        "640": "page-sm", "680": "page-sm", "720": "page-sm",
        "920": "page", "940": "page", "1100": "page", "1200": "page",
        "1300": "page-lg", "1480": "page-lg"
      },
      "ch": {
        "36": "col-sm",
        "55": "col", "56": "col", "60": "col",
        "70": "col-lg"
      }
    },
    "gap": {
      "px": {
        "2": "xs", "3": "xs", "4": "xs", "5": "xs",
        "6": "sm", "8": "sm", "9": "sm",
        "10": "md", "12": "md", "14": "md",
        "16": "lg", "18": "lg", "20": "lg",
        "22": "xl", "24": "xl", "26": "xl", "28": "xl", "30": "xl", "32": "xl", "36": "xl"
      }
    },
    "breakpoints": {
      "px": {
        "540px":  "xs",
        "600px":  "sm",
        "700px":  "md",
        "720px":  "md",
        "760px":  "md",
        "900px":  "lg",
        "1100px": "xl"
      }
    },
    "radius": {
      "px": {
        "2": "1", "3": "2", "4": "3", "6": "4", "8": "5", "10": "6", "12": "7"
      }
    },
    "borderWidths": {
      "px": ["3", "6"]
    },
    "z": {
      "30":   "1",
      "998":  "2",
      "999":  "2",
      "1000": "3"
    },
    "duration": {
      "ms": {
        "120ms": "fast",
        "140ms": "fast"
      }
    }
  },
  "snap": {
    "px": {
      "text": {
        "10": "0.625rem", "10.5": "0.625rem",
        "11": "0.6875rem", "11.5": "0.6875rem",
        "12": "0.75rem", "12.5": "0.75rem",
        "13": "0.8125rem", "13.5": "0.8125rem",
        "14": "0.875rem", "14.5": "0.875rem",
        "15": "1.0625rem", "15.5": "1.0625rem",
        "16": "1.0625rem", "17": "1.0625rem", "17.5": "1.0625rem",
        "18": "1.125rem", "19": "1.125rem", "20": "1.125rem",
